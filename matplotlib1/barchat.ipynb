    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Data\n",
    "categories = ['Cat', 'Dog', 'Bird', 'Fish']\n",
    "counts = [150, 200, 100, 80]\n",
    "\n",
    "plt.bar(categories, counts, color='blue')\n",
    "plt.xlabel(\"Animals\")\n",
    "plt.ylabel(\"Count\")\n",
    "plt.title(\"Animal Dataset\")\n",
    "# plt.grid(True)\n",
    "plt.show()\n"
   ]
