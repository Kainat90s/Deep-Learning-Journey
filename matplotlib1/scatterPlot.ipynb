   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Data\n",
    "house_size = [100, 200, 300, 400, 500]\n",
    "house_price = [1000, 2000, 3000, 4000, 5000]\n",
    "\n",
    "plt.scatter(house_size, house_price, color='green')\n",
    "plt.xlabel(\"House Size\")\n",
    "plt.ylabel(\"House Price\")\n",
    "plt.title(\"House Size vs Price\")\n",
    "plt.show()"
   ]
